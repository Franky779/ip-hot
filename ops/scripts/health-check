#!/usr/bin/env bash
set -euo pipefail

set -a
source /srv/apps/ip-hot/shared/.env.production.local
set +a

home_status=$(curl --silent --show-error --output /dev/null --write-out '%{http_code}' http://127.0.0.1:3101/)
sources_status=$(curl --silent --show-error --output /dev/null --write-out '%{http_code}' http://127.0.0.1:3101/api/sources)
monitor_status=$(curl --silent --show-error --output /dev/null --write-out '%{http_code}' --header "x-admin-password: $ADMIN_PASSWORD" http://127.0.0.1:3101/api/admin/monitor)

printf 'home=%s sources=%s monitor=%s\n' "$home_status" "$sources_status" "$monitor_status"
[[ $home_status == 200 && $sources_status == 200 && $monitor_status == 200 ]]
