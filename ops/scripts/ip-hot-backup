#!/usr/bin/env bash
set -euo pipefail

backup_dir=/srv/backups/postgresql
timestamp=$(date +%Y%m%d-%H%M%S)
target="$backup_dir/ip_hot-$timestamp.dump"

install -d -m 0750 -o postgres -g postgres "$backup_dir"
runuser -u postgres -- pg_dump --format=custom --file="$target" ip_hot
find "$backup_dir" -maxdepth 1 -type f -name 'ip_hot-*.dump' -mtime +7 -delete

